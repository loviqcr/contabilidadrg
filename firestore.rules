rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Libro contable único, compartido por todos los usuarios del negocio
    // (admin y empleados) — cualquiera con una cuenta ve y edita lo mismo.
    match /business/{docId} {
      allow read, write: if request.auth != null;

      match /products/{productId} {
        allow read, write: if request.auth != null;
      }
    }

    // Modelo anterior (un libro por usuario). Se deja solo para que la
    // migración de una sola vez pueda leer los datos viejos del admin.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /products/{productId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Solo el admin puede leer el directorio de usuarios. La escritura ocurre
    // al crear la cuenta (ver createUserAsAdmin), momento en el que quien está
    // autenticado es el usuario recién creado, no el admin — mismo modelo de
    // riesgo aceptado que la creación de cuentas en sí (ver auditoría).
    match /userDirectory/{uid} {
      allow read: if request.auth != null && request.auth.token.email == "loviqcr@gmail.com";
      allow write: if request.auth != null;
    }

    // Mapeo usuario→correo interno, para poder iniciar sesión con un nombre de
    // usuario en vez de un correo. Debe poder leerse sin estar autenticado
    // todavía (es lo que se consulta justo antes de iniciar sesión).
    match /usernames/{username} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
